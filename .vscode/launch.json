  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch dev.js",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/dev.js",
      "env": {
        "tmpPath": "${workspaceFolder}/tmp",
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch runWorkflows.js",
      "skipFiles": [
        "<node_internals>/**"
      ],
      "program": "${workspaceFolder}/runWorkflows.js",
      "env": {
        "tmpPath": "${workspaceFolder}/tmp",
      }
    },
  ]
}